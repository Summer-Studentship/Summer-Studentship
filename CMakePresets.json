{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "windows-mingw-vcpkg",
      "displayName": "Windows MinGW, vcpkg deps, Qt installer",
      "description": "Uses vcpkg for project dependencies and QT_ROOT for a Qt installer build such as C:/Qt/6.11.1/mingw_64.",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "environment": {
        "VCPKG_MAX_CONCURRENCY": "2"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_COMPILER": "$env{MINGW_ROOT}/bin/gcc.exe",
        "CMAKE_CXX_COMPILER": "$env{MINGW_ROOT}/bin/g++.exe",
        "CMAKE_CXX_STANDARD": "20",
        "CMAKE_CXX_STANDARD_REQUIRED": "ON",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_MAKE_PROGRAM": "$env{NINJA_EXE}",
        "CMAKE_PREFIX_PATH": "$env{QT_ROOT}",
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-mingw-dynamic"
      }
    },
    {
      "name": "windows-mingw-vcpkg-all",
      "displayName": "Windows MinGW, vcpkg deps including Qt/mathplot",
      "description": "Uses vcpkg for core, visualization, and GUI packages. This can take much longer because Qt is built/installed by vcpkg.",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "environment": {
        "VCPKG_MAX_CONCURRENCY": "2"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_COMPILER": "$env{MINGW_ROOT}/bin/gcc.exe",
        "CMAKE_CXX_COMPILER": "$env{MINGW_ROOT}/bin/g++.exe",
        "CMAKE_CXX_STANDARD": "20",
        "CMAKE_CXX_STANDARD_REQUIRED": "ON",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_MAKE_PROGRAM": "$env{NINJA_EXE}",
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_MANIFEST_FEATURES": "visualization;gui",
        "VCPKG_TARGET_TRIPLET": "x64-mingw-dynamic"
      }
    },
    {
      "name": "linux-vcpkg-headless",
      "displayName": "Linux headless core build with vcpkg",
      "description": "Builds the non-GUI project configuration for Docker and CI.",
      "inherits": "linux-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "TSUNAMI_BUILD_GUI": "OFF",
        "TSUNAMI_BUILD_MATPLOT_SMOKE": "OFF",
        "TSUNAMI_BUILD_TESTS": "OFF"
      }
    },
    {
      "name": "linux-gui-debug",
      "displayName": "Linux Qt Widgets GUI debug build",
      "description": "Builds the repository-level Qt Widgets GUI using system Qt 6 and no vcpkg Qt feature.",
      "inherits": "linux-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "TSUNAMI_BUILD_GUI": "ON",
        "TSUNAMI_BUILD_MATPLOT_SMOKE": "OFF",
        "TSUNAMI_BUILD_TESTS": "OFF"
      }
    },
    {
      "name": "linux-base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "environment": {
        "VCPKG_MAX_CONCURRENCY": "2"
      },
      "cacheVariables": {
        "CMAKE_CXX_STANDARD": "20",
        "CMAKE_CXX_STANDARD_REQUIRED": "ON",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-linux"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-mingw-vcpkg-debug",
      "configurePreset": "windows-mingw-vcpkg"
    },
    {
      "name": "windows-mingw-vcpkg-all-debug",
      "configurePreset": "windows-mingw-vcpkg-all"
    },
    {
      "name": "linux-vcpkg-headless-build",
      "configurePreset": "linux-vcpkg-headless"
    },
    {
      "name": "linux-gui-debug-build",
      "configurePreset": "linux-gui-debug",
      "targets": [
        "TsunamiGUI"
      ]
    }
  ]
}
