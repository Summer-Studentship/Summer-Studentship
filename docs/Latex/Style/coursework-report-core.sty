% Custom section-tier syntax.
% The public form is \SECTION_TIER_1{Title} through \SECTION_TIER_5{Title}.
% TeX reads \SECTION as the control sequence and the literal _TIER_# suffix as
% delimited arguments, allowing the requested syntax without changing catcodes.
\newcommand{\courseworksectiontier}[2]{%
  \ifcase\numexpr#1\relax
    \PackageError{coursework-report-core}
      {Unsupported section tier '#1'}
      {Valid section tiers are 1, 2, 3, 4, and 5.}%
  \or
    \section{#2}%
  \or
    \subsection{#2}%
  \or
    \subsubsection{#2}%
  \or
    \paragraph{#2}%
  \or
    \subparagraph{#2}%
  \else
    \PackageError{coursework-report-core}
      {Unsupported section tier '#1'}
      {Valid section tiers are 1, 2, 3, 4, and 5.}%
  \fi
}
\long\def\SECTION_TIER_#1#2{%
  \courseworksectiontier{#1}{#2}%
}

\newcount\courseworksmartsubsectionbase
\courseworksmartsubsectionbase=2\relax
\makeatletter
\newcommand{\coursework@smartsubsectionlevel@section}{\courseworksmartsubsectionbase=1\relax}
\newcommand{\coursework@smartsubsectionlevel@subsection}{\courseworksmartsubsectionbase=2\relax}
\newcommand{\coursework@smartsubsectionlevel@subsubsection}{\courseworksmartsubsectionbase=3\relax}
\newcommand{\coursework@smartsubsectionlevel@paragraph}{\courseworksmartsubsectionbase=4\relax}
\newcommand{\coursework@smartsubsectionlevel@subparagraph}{\courseworksmartsubsectionbase=5\relax}
\newcommand{\setsmartsubsectionlevel}[1]{%
  \@ifundefined{coursework@smartsubsectionlevel@#1}
    {%
      \PackageError{coursework-report-core}{Unsupported smart subsection level '#1'}%
      {Valid values are section, subsection, subsubsection, paragraph, and subparagraph.}%
    }
    {\csname coursework@smartsubsectionlevel@#1\endcsname}%
}

\NewDocumentCommand{\smartsubsection}{s O{0} m}{%
  \begingroup
  \count@=\courseworksmartsubsectionbase\relax
  \advance\count@ by #2\relax
  \ifnum\count@<1\relax
    \count@=1\relax
  \fi
  \ifnum\count@>5\relax
    \count@=5\relax
  \fi
  \ifnum\count@=1\relax
    \endgroup
    \IfBooleanTF{#1}{\section*{#3}}{\section{#3}}%
  \else\ifnum\count@=2\relax
    \endgroup
    \IfBooleanTF{#1}{\subsection*{#3}}{\subsection{#3}}%
  \else\ifnum\count@=3\relax
    \endgroup
    \IfBooleanTF{#1}{\subsubsection*{#3}}{\subsubsection{#3}}%
  \else\ifnum\count@=4\relax
    \endgroup
    \IfBooleanTF{#1}{\paragraph*{#3}}{\paragraph{#3}}%
  \else
    \endgroup
    \IfBooleanTF{#1}{\subparagraph*{#3}}{\subparagraph{#3}}%
  \fi\fi\fi\fi
}
\makeatother

