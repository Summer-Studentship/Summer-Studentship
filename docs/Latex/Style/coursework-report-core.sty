% Smart references that group same-prefix labels and split mixed prefixes.
\newbool{smartreffirstitem}
\newbool{smartrefsametype}
\newcommand{\smartreftypefromlabel}[1]{%
  \def\smartreftype{ref}%
  \IfBeginWith{#1}{fig:}{\def\smartreftype{fig}}{}%
  \IfBeginWith{#1}{alg:}{\def\smartreftype{alg}}{}%
  \IfBeginWith{#1}{app:}{\def\smartreftype{app}}{}%
  \IfBeginWith{#1}{ass:}{\def\smartreftype{ass}}{}%
  \IfBeginWith{#1}{tab:}{\def\smartreftype{tab}}{}%
  \IfBeginWith{#1}{eq:}{\def\smartreftype{eq}}{}%
  \IfBeginWith{#1}{sec:}{\def\smartreftype{sec}}{}%
  \IfBeginWith{#1}{lst:}{\def\smartreftype{lst}}{}%
}
\newcommand{\smartrefsingle}[1]{%
  \def\smartrefresult{\ref{#1}}%
  \IfBeginWith{#1}{fig:}{\def\smartrefresult{Figure~\ref{#1}}}{}%
  \IfBeginWith{#1}{alg:}{\def\smartrefresult{Algorithm~\ref{#1}}}{}%
  \IfBeginWith{#1}{app:}{\def\smartrefresult{Appendix~\ref{#1}}}{}%
  \IfBeginWith{#1}{ass:}{\def\smartrefresult{Assumption~\ref{#1}}}{}%
  \IfBeginWith{#1}{tab:}{\def\smartrefresult{Table~\ref{#1}}}{}%
  \IfBeginWith{#1}{eq:}{\def\smartrefresult{Equation~\ref{#1}}}{}%
  \IfBeginWith{#1}{sec:}{\def\smartrefresult{Section~\ref{#1}}}{}%
  \IfBeginWith{#1}{lst:}{\def\smartrefresult{Listing~\ref{#1}}}{}%
  \smartrefresult
}
\makeatletter
\newcommand{\smartrefnumberlist}[1]{%
  \begingroup
  \def\smartrefsep{}%
  \renewcommand*{\do}[1]{%
    \edef\smartreflabel{\trim@spaces{##1}}%
    \smartrefsep\ref{\smartreflabel}%
    \gdef\smartrefsep{, }%
  }%
  \docsvlist{#1}%
  \endgroup
}
\newcommand{\smartrefmixed}[1]{%
  \begingroup
  \def\smartrefsep{}%
  \renewcommand*{\do}[1]{%
    \edef\smartreflabel{\trim@spaces{##1}}%
    \smartrefsep
    \smartrefsingle{\smartreflabel}%
    \gdef\smartrefsep{,~}%
  }%
  \docsvlist{#1}%
  \endgroup
}
\newcommand{\smartrefplural}[2]{%
  \def\smartrefpluralresult{References~[\smartrefnumberlist{#2}]}%
  \ifstrequal{#1}{fig}{\def\smartrefpluralresult{Figures~[\smartrefnumberlist{#2}]}}{}%
  \ifstrequal{#1}{alg}{\def\smartrefpluralresult{Algorithms~[\smartrefnumberlist{#2}]}}{}%
  \ifstrequal{#1}{app}{\def\smartrefpluralresult{Appendices~[\smartrefnumberlist{#2}]}}{}%
  \ifstrequal{#1}{ass}{\def\smartrefpluralresult{Assumptions~[\smartrefnumberlist{#2}]}}{}%
  \ifstrequal{#1}{tab}{\def\smartrefpluralresult{Tables~[\smartrefnumberlist{#2}]}}{}%
  \ifstrequal{#1}{eq}{\def\smartrefpluralresult{Equations~[\smartrefnumberlist{#2}]}}{}%
  \ifstrequal{#1}{sec}{\def\smartrefpluralresult{Sections~[\smartrefnumberlist{#2}]}}{}%
  \ifstrequal{#1}{lst}{\def\smartrefpluralresult{Listings~[\smartrefnumberlist{#2}]}}{}%
  \smartrefpluralresult
}
\newcommand{\smartrefmixedunlesssame}[2]{%
  \def\smartrefmultiresult{\smartrefplural{#1}{#2}}%
  \ifstrequal{#1}{fig}{}{\IfSubStr{#2}{fig:}{\def\smartrefmultiresult{\smartrefmixed{#2}}}{}}%
  \ifstrequal{#1}{alg}{}{\IfSubStr{#2}{alg:}{\def\smartrefmultiresult{\smartrefmixed{#2}}}{}}%
  \ifstrequal{#1}{app}{}{\IfSubStr{#2}{app:}{\def\smartrefmultiresult{\smartrefmixed{#2}}}{}}%
  \ifstrequal{#1}{ass}{}{\IfSubStr{#2}{ass:}{\def\smartrefmultiresult{\smartrefmixed{#2}}}{}}%
  \ifstrequal{#1}{tab}{}{\IfSubStr{#2}{tab:}{\def\smartrefmultiresult{\smartrefmixed{#2}}}{}}%
  \ifstrequal{#1}{eq}{}{\IfSubStr{#2}{eq:}{\def\smartrefmultiresult{\smartrefmixed{#2}}}{}}%
  \ifstrequal{#1}{sec}{}{\IfSubStr{#2}{sec:}{\def\smartrefmultiresult{\smartrefmixed{#2}}}{}}%
  \ifstrequal{#1}{lst}{}{\IfSubStr{#2}{lst:}{\def\smartrefmultiresult{\smartrefmixed{#2}}}{}}%
  \smartrefmultiresult
}
\newcommand{\smartrefmulti}[1]{%
  \StrBefore{#1}{,}[\FirstSmartRefLabelRaw]%
  \edef\FirstSmartRefLabel{\trim@spaces{\FirstSmartRefLabelRaw}}%
  \def\smartrefmultiresult{\smartrefmixedunlesssame{ref}{#1}}%
  \IfBeginWith{\FirstSmartRefLabel}{fig:}{\def\smartrefmultiresult{\smartrefmixedunlesssame{fig}{#1}}}{}%
  \IfBeginWith{\FirstSmartRefLabel}{alg:}{\def\smartrefmultiresult{\smartrefmixedunlesssame{alg}{#1}}}{}%
  \IfBeginWith{\FirstSmartRefLabel}{app:}{\def\smartrefmultiresult{\smartrefmixedunlesssame{app}{#1}}}{}%
  \IfBeginWith{\FirstSmartRefLabel}{ass:}{\def\smartrefmultiresult{\smartrefmixedunlesssame{ass}{#1}}}{}%
  \IfBeginWith{\FirstSmartRefLabel}{tab:}{\def\smartrefmultiresult{\smartrefmixedunlesssame{tab}{#1}}}{}%
  \IfBeginWith{\FirstSmartRefLabel}{eq:}{\def\smartrefmultiresult{\smartrefmixedunlesssame{eq}{#1}}}{}%
  \IfBeginWith{\FirstSmartRefLabel}{sec:}{\def\smartrefmultiresult{\smartrefmixedunlesssame{sec}{#1}}}{}%
  \IfBeginWith{\FirstSmartRefLabel}{lst:}{\def\smartrefmultiresult{\smartrefmixedunlesssame{lst}{#1}}}{}%
  \smartrefmultiresult
}
\makeatletter
\newcommand{\smartref}[1]{%
  \IfSubStr{#1}{,}
    {\smartrefmulti{#1}}
    {\smartrefsingle{#1}}%
}
\makeatother
