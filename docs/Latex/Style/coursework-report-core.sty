% Compress only runs of four or more consecutive citation numbers.
% Example:
% - \cite{a,b,c}   -> 1,2,3
% - \cite{a,b,c,d} -> 1-4
\makeatletter
\global\let\cbx@shortseq\@empty

\newcommand*{\cbx@printlinkedlabel}[3]{%
  \printtext{\bibhyperref[#1]{%
    \ifstrempty{#2}
      {}
      {\printtext[labelprefix]{#2}}%
    \printtext[labelnumber]{#3}}}}

\newcommand*{\cbx@addshortseqentry}{%
  \iffieldundef{labelprefix}
    {\xappto\cbx@shortseq{%
       \noexpand\setunit{\noexpand\multicitedelim}%
       \noexpand\cbx@printlinkedlabel{\thefield{entrykey}}{}{\thefield{labelnumber}}}}
    {\xappto\cbx@shortseq{%
       \noexpand\setunit{\noexpand\multicitedelim}%
       \noexpand\cbx@printlinkedlabel{\thefield{entrykey}}{\thefield{labelprefix}}{\thefield{labelnumber}}}}}

\renewbibmacro*{cite:init}{%
  \global\boolfalse{cbx:parens}%
  \global\undef\cbx@lasthash
  \global\undef\cbx@lastnumber
  \global\undef\cbx@lastprefix
  \global\undef\cbx@lastentrysetcount
  \global\let\cbx@shortseq\@empty
  \setcounter{cbx@tempcnta}{0}%
  \setcounter{cbx@tempcntb}{-2}%
  \setcounter{cbx@tempcntc}{0}%
  \setcounter{cbx@tempcntd}{-1}}

\renewbibmacro*{cite:comp:comp}{%
  \cbx@iflabelprefixequalslast
    {\ifnumequal{\thefield{labelnumber}}{\value{cbx@tempcntb}}
       {\savefield{entrykey}{\cbx@lastkey}%
        \savefield{labelnumber}{\cbx@lastnumber}%
        \cbx@addshortseqentry%
        \stepcounter{cbx@tempcnta}}
       {\ifnumequal{\thefield{labelnumber}}{\value{cbx@tempcntb}-1}
          {%
          }
          {\usebibmacro{cite:comp:end}}}}
    {\usebibmacro{cite:comp:end}}%
  \setcounter{cbx@tempcntb}{\thefield{labelnumber}}%
  \savefield{labelprefix}{\cbx@lastprefix}}

\newbibmacro*{cite:print:shortrange}{%
  \cbx@shortseq}

\renewbibmacro*{cite:dump}{%
  \usebibmacro{cite:dump:inset}%
  \ifnumgreater{\value{cbx@tempcnta}}{0}
    {%
      \ifnumgreater{\value{cbx@tempcnta}}{2}
        {%
          \setunit{\multiciterangedelim}%
          \usebibmacro{cite:print:last:labelnumber}%
        }%
        {%
          \usebibmacro{cite:print:shortrange}%
        }%
      \global\undef\cbx@lastprefix
    }%
    {}%
  \global\let\cbx@shortseq\@empty
  \setcounter{cbx@tempcnta}{0}%
}
\makeatother

